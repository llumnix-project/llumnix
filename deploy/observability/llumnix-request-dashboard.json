{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "description": "", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 101, "title": "Request Rate", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Requests/s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1, "title": "Request Rate", "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(request_total{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "req/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Requests/s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 20, "title": "Request Rate by Status", "type": "timeseries",
      "targets": [
        { "expr": "sum by(status_code) (rate(request_total{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "HTTP {{ status_code }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Requests/s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 22, "title": "Request Retry & Fallback Rate", "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(request_retry_total{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "retry/s" },
        { "expr": "sum(rate(request_fallback_total{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "fallback/s" },
        { "expr": "sum(rate(request_fallback_retry_success_total{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "fallback_retry_ok/s" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }, "id": 102, "title": "Request Throughput", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "Tps", "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Tokens/s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 4, "title": "Input Token Throughput", "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(request_input_tokens_total{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "input token/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "Tps", "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Tokens/s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 5, "title": "Output Token Throughput", "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(request_output_tokens_total{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "output token/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 23,
      "title": "Input Token Distribution",
      "type": "heatmap",
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Spectral",
          "steps": 64
        },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "yAxis": {
          "axisLabel": "Input Tokens",
          "axisPlacement": "left",
          "reverse": false,
          "unit": "none"
        },
        "tooltip": {
          "mode": "single",
          "showColorScale": false,
          "yHistogram": true
        }
      },
      "targets": [
        { "expr": "sum by(le) (increase(request_input_tokens_bucket{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "{{le}}", "format": "heatmap" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 24,
      "title": "Output Token Distribution",
      "type": "heatmap",
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Spectral",
          "steps": 64
        },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "yAxis": {
          "axisLabel": "Output Tokens",
          "axisPlacement": "left",
          "reverse": false,
          "unit": "none"
        },
        "tooltip": {
          "mode": "single",
          "showColorScale": false,
          "yHistogram": true
        }
      },
      "targets": [
        { "expr": "sum by(le) (increase(request_output_tokens_bucket{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "{{le}}", "format": "heatmap" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }, "id": 103, "title": "Request Latency", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Latency (s)" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "id": 10, "title": "E2E Latency (seconds)", "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by(le) (rate(request_e2e_latency_seconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P99" },
        { "expr": "histogram_quantile(0.95, sum by(le) (rate(request_e2e_latency_seconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.9, sum by(le) (rate(request_e2e_latency_seconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P90" },
        { "expr": "histogram_quantile(0.5, sum by(le) (rate(request_e2e_latency_seconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P50" },
        { "expr": "sum(rate(request_e2e_latency_seconds_sum{namespace=\"$namespace\"}[$__rate_interval])) / sum(rate(request_e2e_latency_seconds_count{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "Avg" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Latency (ms)" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "id": 11, "title": "Time To First Token - TTFT (ms)", "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by(le) (rate(request_ttft_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P99" },
        { "expr": "histogram_quantile(0.95, sum by(le) (rate(request_ttft_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.9, sum by(le) (rate(request_ttft_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P90" },
        { "expr": "histogram_quantile(0.5, sum by(le) (rate(request_ttft_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P50" },
        { "expr": "sum(rate(request_ttft_milliseconds_sum{namespace=\"$namespace\"}[$__rate_interval])) / sum(rate(request_ttft_milliseconds_count{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "Avg" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Latency (ms)" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "id": 13, "title": "Time Per Output Token - TPOT (ms)", "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by(le) (rate(request_tpot_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P99" },
        { "expr": "histogram_quantile(0.95, sum by(le) (rate(request_tpot_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.9, sum by(le) (rate(request_tpot_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P90" },
        { "expr": "histogram_quantile(0.5, sum by(le) (rate(request_tpot_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P50" },
        { "expr": "sum(rate(request_tpot_milliseconds_sum{namespace=\"$namespace\"}[$__rate_interval])) / sum(rate(request_tpot_milliseconds_count{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "Avg" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Latency (ms)" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "id": 12, "title": "Inter-Token Latency - ITL (ms)", "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by(le) (rate(request_itl_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P99" },
        { "expr": "histogram_quantile(0.95, sum by(le) (rate(request_itl_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.9, sum by(le) (rate(request_itl_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P90" },
        { "expr": "histogram_quantile(0.5, sum by(le) (rate(request_itl_milliseconds_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P50" },
        { "expr": "sum(rate(request_itl_milliseconds_sum{namespace=\"$namespace\"}[$__rate_interval])) / sum(rate(request_itl_milliseconds_count{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "Avg" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 }, "id": 104, "title": "Request Prefix Cache", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Hit Ratio (%)" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 },
