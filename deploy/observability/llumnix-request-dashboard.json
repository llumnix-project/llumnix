        { "expr": "histogram_quantile(0.95, sum by(le) (increase(request_prefix_cache_hit_percent_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.9, sum by(le) (increase(request_prefix_cache_hit_percent_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P90" },
        { "expr": "histogram_quantile(0.5, sum by(le) (increase(request_prefix_cache_hit_percent_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P50" },
        { "expr": "sum(increase(request_prefix_cache_hit_percent_sum{namespace=\"$namespace\"}[$__rate_interval])) / sum(increase(request_prefix_cache_hit_percent_count{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "Avg" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Hit Ratio (%)" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 52 },
      "id": 37, "title": "Max Prefix Cache Hit Ratio (%)", "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by(le) (increase(request_max_prefix_cache_hit_percent_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P99" },
        { "expr": "histogram_quantile(0.95, sum by(le) (increase(request_max_prefix_cache_hit_percent_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.9, sum by(le) (increase(request_max_prefix_cache_hit_percent_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P90" },
        { "expr": "histogram_quantile(0.5, sum by(le) (increase(request_max_prefix_cache_hit_percent_bucket{namespace=\"$namespace\"}[$__rate_interval])))", "legendFormat": "P50" },
        { "expr": "sum(increase(request_max_prefix_cache_hit_percent_sum{namespace=\"$namespace\"}[$__rate_interval])) / sum(increase(request_max_prefix_cache_hit_percent_count{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "Avg" }
      ]
    }
