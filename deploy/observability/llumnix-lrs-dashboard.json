  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 106, "title": "Instance Status (LRS) - Prefill", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0 }, "axisLabel": "Requests" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 60,
      "title": "LRS Requests (Prefill)",
      "type": "timeseries",
      "targets": [
        { "expr": "instance_lrs_total_requests{namespace=\"$namespace\", infer_type=\"prefill\"} - instance_lrs_waiting_requests{namespace=\"$namespace\", infer_type=\"prefill\"}", "legendFormat": "{{ instance_id }} running" },
        { "expr": "instance_lrs_waiting_requests{namespace=\"$namespace\", infer_type=\"prefill\"}", "legendFormat": "{{ instance_id }} waiting" },
        { "expr": "instance_lrs_total_requests{namespace=\"$namespace\", infer_type=\"prefill\"}", "legendFormat": "{{ instance_id }} total" }
      ]
    },
