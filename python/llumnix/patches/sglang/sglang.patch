+class MigrationBootstrapQueue(PrefillBootstrapQueue):
+    def _init_kv_manager(self):
+        pass
+
+    def _process_req(self, req: Req) -> None:
+        pass
+
+    def pop_bootstrapped(
+        self,
+    ) -> List[Req]:
+
+        if len(self.queue) == 0:
+            return []
+
+        bootstrapped_reqs = []
+        indices_to_remove = set()
+        polls = poll_and_all_reduce(
+            [req.disagg_kv_sender for req in self.queue], self.gloo_group
+        )
+        for i, (req, poll) in enumerate(zip(self.queue, polls)):
+            if poll == KVPoll.Bootstrapping:
+                continue
+            elif poll == KVPoll.Failed:
+                error_message = f"Migration bootstrapped failed for request rank={self.tp_rank} {req.rid=} {req.bootstrap_room=}"
+                try:
+                    req.disagg_kv_sender.failure_exception()
+                except Exception as e:
+                    error_message += f" with exception {e}"
+                logger.error(error_message)
+                indices_to_remove.add(i)
+                continue
+            # KV.WaitingForInput - init here
+            num_kv_indices = req.seqlen_before_migration - 1
+            if self.req_to_metadata_buffer_idx_allocator.available_size() == 0:
+                break
+
+            req.metadata_buffer_index = (
+                self.req_to_metadata_buffer_idx_allocator.alloc()
+            )
+            assert req.metadata_buffer_index is not None
+
+            # num pages will set in last stage migration
+            num_pages = 0
+            req.disagg_kv_sender.init(num_pages, req.metadata_buffer_index)
+            bootstrapped_reqs.append(req)
+            indices_to_remove.add(i)
+
+        self.queue = [
+            entry for i, entry in enumerate(self.queue) if i not in indices_to_remove
+        ]
+        return bootstrapped_reqs
+
+        
 
