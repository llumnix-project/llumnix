+    def abort_migrate_in_request(self: Scheduler, recv_req: AbortMigrateInReq):
+        for decode_req in (self.disagg_decode_transfer_queue.queue + self.disagg_decode_prealloc_queue.queue):
+            if decode_req.req.rid == recv_req.rid:
+                logger.info(f"migrate in {decode_req.req.rid=} abort migration")
+                self.disagg_decode_prealloc_queue.kv_manager.record_failure(decode_req.req.bootstrap_room, "abort migration from dst")
+                decode_req.kv_receiver.conclude_state = KVPoll.Failed
+                return AbortMigrateInReqOutput(True, "")
+        return AbortMigrateInReqOutput(False, "no req in disagg_decode_transfer_queue and disagg_decode_prealloc_queue")
+
+    def _should_abort_migration(self: Scheduler, reqs: List[Req]):
+        for req in reqs:
+            abort_migration = False
+            abort_reason = "abort migration from src"
+            new_output_len = req.seqlen - req.seqlen_before_migration
+            if new_output_len > self.disagg_metadata_buffers.max_output_len or new_output_len < 0:
+                abort_reason = "new output len is out of range"
+                abort_migration = True
+            if req not in self.running_batch.reqs or req.finished():
+                abort_migration = True
+                abort_reason = "req is not in running batch or finished"
+            if abort_migration:
+                # TODO failure_exception
+                logger.info(f"migrate out {req.rid=} abort migration")
+                self.migration_bootstrap_queue.kv_manager.record_failure(req.bootstrap_room, abort_reason)
+                req.disagg_kv_sender.conclude_state = KVPoll.Failed
+                abort_migrate_in_req = AbortMigrateInReq(req.rid, req.migrate_in_ip_address, req.migrate_in_port)
+                if self.attn_tp_rank == 0:
+                    self.send_to_llumlet.send_pyobj(abort_migrate_in_req)
+                # sync to decode
+
+    def process_migration_bootstrap_queue(self: Scheduler):
+        self._should_abort_migration(self.migration_bootstrap_queue.queue)
+
+        reqs_to_send_kv = self.migration_bootstrap_queue.pop_bootstrapped()
+        for req in reqs_to_send_kv:
+            req.prestage_start_time = time.time()
+            logger.info(f"pre stage send {req.rid=}")
+            self.send_kv_chunk(req, end_idx=req.seqlen_before_migration - 1, last_chunk=False, is_migration=True)
+        self.migration_pre_stage_queue.extend(reqs_to_send_kv)
+
+    def process_migration_pre_stage_queue(self: Scheduler):
+        if len(self.migration_pre_stage_queue) == 0:
+            return
+        self._should_abort_migration(self.migration_pre_stage_queue)
+
+        polls = poll_and_all_reduce(
+            [req.disagg_kv_sender for req in self.migration_pre_stage_queue],
+            self.attn_tp_cpu_group,
+        )
+
+        undone_reqs: List[Req] = []
+        reqs_to_send_kv: List[Req] = []
+        done_reqs: List[Req] = []
+        for req, poll in zip(self.migration_pre_stage_queue, polls):
+            if poll == KVPoll.WaitingForInput:
+                undone_reqs.append(req)
+            elif poll == KVPoll.Transferring:
+                reqs_to_send_kv.append(req)
+            elif poll == KVPoll.Failed:
+                error_message = f"Migration pre_stage transfering failed for request rank={self.tp_rank} {req.rid=} {req.bootstrap_room=}"
+                try:
+                    req.disagg_kv_sender.failure_exception()
+                except Exception as e:
+                    error_message += f" with exception {e}"
+                logger.error(error_message)
+                self.req_to_metadata_buffer_idx_allocator.free(req.metadata_buffer_index)
+            else:
+                assert False, f"Unexpected polling state {poll=}, {req=}"
+        for req in reqs_to_send_kv:
+            logger.info(f"last stage send {req.rid=}")
+            req.laststage_start_time = time.time()
+            if req.seqlen == req.seqlen_before_migration:
+                # last chunk is empty, so we do not send
+                undone_reqs.append(req)
+            else:
+                self.send_kv_chunk(req, end_idx=req.seqlen - 1, last_chunk=True, is_migration=True)
+                done_reqs.append(req)
+            
+        self.running_batch.filter_batch()
+        keep_indices = [idx for idx, req in enumerate(self.running_batch.reqs) if req not in done_reqs]
+        self.running_batch.filter_batch(keep_indices=keep_indices, spec_has_been_filtered=False)
+
+        self.migration_last_stage_queue.extend(done_reqs)
+        self.migration_pre_stage_queue = undone_reqs
+
+    def process_migration_last_stage_queue(self: Scheduler):
+        if len(self.migration_last_stage_queue) == 0:
+            return
+        polls = poll_and_all_reduce(
+            [req.disagg_kv_sender for req in self.migration_last_stage_queue],
+            self.attn_tp_cpu_group,
+        )
+        undone_reqs: List[Req] = []
+        done_reqs: List[Req] = []
+        for req, poll in zip(self.migration_last_stage_queue, polls):
+            if poll == KVPoll.Transferring:
+                undone_reqs.append(req)
+            elif poll == KVPoll.Success:
+                done_reqs.append(req)
+            elif poll == KVPoll.Failed:
+                error_message = f"Migration last_stage transferring failed for request rank={self.tp_rank} {req.rid=} {req.bootstrap_room=}"
+                try:
+                    req.disagg_kv_sender.failure_exception()
+                except Exception as e:
+                    error_message += f" with exception {e}"
+                logger.error(error_message)
+                self.req_to_metadata_buffer_idx_allocator.free(req.metadata_buffer_index)
+                # TODO put back to running batch
+
+            else:
+                assert False, f"Unexpected polling state {poll=}"
+        
+        for req in done_reqs:
+            logger.info(f"last stage finish {req.rid=}")
+            req.laststage_finished_time = time.time()
+            logger.info(f"req {req.rid=} migration cost: {(req.laststage_finished_time-req.migrate_start_time)*1000}ms, pre stage cost:{(req.laststage_start_time-req.prestage_start_time)*1000}ms, pre stage cost:{(req.laststage_finished_time-req.laststage_start_time)*1000}ms, tot transfer tokens:{len(req.fill_ids)}")
+            if req.finished():
+                logger.warning(f"{req.rid=} finshed before last stage migration")
+            else:
+                self.tree_cache.cache_finished_req(req)
+                self.req_to_metadata_buffer_idx_allocator.free(req.metadata_buffer_index)
+            
+        self.migration_last_stage_queue = undone_reqs
+
+    def migrate_out(
+        self: Scheduler,
+        recv_req: MigrateOutReq,
+    ):
+        if self.running_batch is not None and len(self.running_batch.reqs) > 0:
+            idx = random.randint(0, len(self.running_batch.reqs) - 1)
+            if self.running_batch.reqs[idx].disagg_kv_sender is not None:
+                return self._create_empty_migrate_in_req()
+            # decide by llumnix, fake it for debugging
+            migrate_out_req = self.running_batch.reqs[idx]
+            migrate_out_req.bootstrap_room = random.randint(0, 2**63 - 1)
+            if self.dp_size > 1:
+                migrate_out_req.bootstrap_room = migrate_out_req.bootstrap_room // self.dp_size * self.dp_size + self.dp_rank
+            migrate_out_req.bootstrap_port = self.server_args.disaggregation_bootstrap_port
+            migrate_out_req.bootstrap_host = self.migration_bootstrap_host
+            migrate_out_req.migrate_in_ip_address = recv_req.migrate_in_ip_address
+            migrate_out_req.migrate_in_port = recv_req.migrate_in_port
+
+            tokenized_req = TokenizedGenerateReqInput(
+                migrate_out_req.rid,
+                migrate_out_req.origin_input_text,
+                migrate_out_req.origin_input_ids,
+                None,
+                migrate_out_req.sampling_params,
+                migrate_out_req.return_logprob,
+                None,
+                migrate_out_req.top_logprobs_num,
+                migrate_out_req.token_ids_logprob,
+                migrate_out_req.stream,
+                migrate_out_req.return_hidden_states,
+                migrate_out_req.lora_id,
+                migrate_out_req.input_embeds,
+                custom_logit_processor=migrate_out_req.custom_logit_processor,
+                bootstrap_host=migrate_out_req.bootstrap_host,
+                bootstrap_port=migrate_out_req.bootstrap_port,
+                bootstrap_room=migrate_out_req.bootstrap_room,
+                data_parallel_rank=0,
+            )
+            migrate_out_req.seqlen_before_migration = migrate_out_req.seqlen
+            detokenizer_ipc_name = migrate_out_req.src_detokenizer_ipc_name if hasattr(migrate_out_req, "src_detokenizer_ipc_name") else self.detokenizer_ipc_name 
