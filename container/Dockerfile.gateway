FROM ubuntu:22.04

RUN apt-get update && apt-get install -y ca-certificates git curl wget vim \
    && rm -rf /var/lib/apt/lists/*

COPY ./bin/* /usr/local/bin/

COPY ./lib/resources /tokenizers

COPY ./lib/sgl-model-gateway/sgl-model-gateway/bindings/golang/target/release/*.a /usr/lib

WORKDIR /app
